# Database: SQLite (local) or PostgreSQL (production)
# SQLite: sqlite:///./construgest.db
# PostgreSQL: postgresql://user:password@host:5432/construgest
DATABASE_URL=sqlite:///./construgest.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://construgest.vercel.app"]

# Debug
DEBUG=true
